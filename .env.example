# ============================================
# SalesAgent AI — Environment Configuration
# ============================================

# ============================================
# AI PROVIDER — pick ONE and set its key
# ============================================
# Options: groq | gemini | anthropic | openai | ollama
# Recommended for free demo: groq
LLM_PROVIDER=groq

# Groq (FREE, fast — recommended)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free tier, 1500 req/day)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (paid, $5 free trial for new accounts)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (paid)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama (local, free, requires Ollama installed on host)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/salesagent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=salesagent

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# SendGrid (optional — leave empty for mock email send)
# ============================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=outreach@example.com
SENDGRID_FROM_NAME=SalesAgent AI
SENDGRID_WEBHOOK_SECRET=

# ============================================
# Enrichment APIs (optional — graceful degradation if missing)
# ============================================
NEWS_API_KEY=
BUILTWITH_API_KEY=
LINKEDIN_API_KEY=

# ============================================
# Auth
# ============================================
JWT_SECRET_KEY=change-me-in-production-this-must-be-very-long-and-random
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================
# App config
# ============================================
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
AUTOPILOT_MODE=false
CONFIDENCE_THRESHOLD=0.65

# ============================================
# Compliance
# ============================================
COMPANY_PHYSICAL_ADDRESS=123 Demo Street, San Francisco, CA 94103
UNSUBSCRIBE_BASE_URL=http://localhost:8000/unsubscribe
